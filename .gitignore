# ==============================================================================
# ARCHIVO: .gitignore - Be Fit Real
# 
# OBJETIVO: Define qué archivos y carpetas deben ser ignorados por Git.
# ESTRATEGIA: Se filtran archivos temporales, configuraciones de IDE locales y,
# sobre todo, credenciales sensibles para garantizar la seguridad del proyecto.
# ==============================================================================

# --- SEGURIDAD Y CREDENCIALES (CRÍTICO) ---
# Evita la fuga de API Keys (Gemini) y secretos de producción.
.env
*.pem
*.key

# --- FLUTTER / DART / PUB ---
# Archivos generados automáticamente durante la compilación.
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
build/
**/doc/api/
**/ios/Flutter/.last_build_id

# --- ARTEFACTOS DE COMPILACIÓN ANDROID ---
/android/app/debug
/android/app/profile
/android/app/release
*.apk
*.aab
*.jks

# --- CONFIGURACIÓN DE IDEs (LOCAL) ---
# IntelliJ / Android Studio
*.iml
*.ipr
*.iws
.idea/

# Visual Studio Code
# Nota: No ignoramos .vscode/ completo porque puede contener 
# tareas de proyecto compartidas, pero sí archivos personales.
.vscode/settings.json
.vscode/bin/
.vscode/obj/

# --- ARCHIVOS DE SISTEMA Y TEMPORALES ---
.DS_Store
Thumbs.db
*.log
*.swp
*.class
.history
migrate_working_dir/

# --- DEPURACIÓN Y SÍMBOLOS ---
app.*.symbols
app.*.map.json